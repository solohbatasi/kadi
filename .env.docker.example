APP_NAME=Kadi
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://payments.example.com
APP_PORT=8000
SERVER_PORT=8000

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=info

DB_CONNECTION=pgsql
DB_HOST=postgres.example.internal
DB_PORT=5432
DB_DATABASE=kadi
DB_USERNAME=kadi
DB_PASSWORD=

SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

MPESA_ENV=production
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=https://payments.example.com/api/mpesa/stk-callback/your-secret
MPESA_CALLBACK_SECRET=
MPESA_TIMEOUT=30
MPESA_B2C_INITIATOR_NAME=
MPESA_B2C_SECURITY_CREDENTIAL=
MPESA_B2C_COMMAND_ID=BusinessPayment
MPESA_B2C_RESULT_URL=https://payments.example.com/api/mpesa/b2c/result/your-secret
MPESA_B2C_TIMEOUT_URL=https://payments.example.com/api/mpesa/b2c/timeout/your-secret
MPESA_B2C_QUEUE_TIMEOUT_URL=
MPESA_B2C_FAKE=false
MPESA_B2C_FAKE_RESULT=success

PAYMENT_PLATFORM_NAME=Kadi
PAYMENT_DEFAULT_COMMISSION_TYPE=percentage
PAYMENT_DEFAULT_COMMISSION_PERCENT=2.0
PAYMENT_DEFAULT_COMMISSION_FLAT=0
PAYMENT_MIN_STK_AMOUNT=10
PAYMENT_MIN_PAYOUT_AMOUNT=10
PAYMENT_PENDING_TRANSACTION_TIMEOUT_MINUTES=15
PAYMENT_IDEMPOTENCY_KEY_RETENTION_DAYS=1
PAYMENT_ALLOW_SANDBOX_PAYOUTS_WITHOUT_VERIFIED_COMPLIANCE=false
PAYMENT_DEFAULT_CURRENCY=KES

OPERATIONS_ALERT_EMAIL=
OPERATIONS_ALERT_FAILED_WEBHOOK_THRESHOLD=10
OPERATIONS_ALERT_PENDING_PAYOUT_THRESHOLD=10
OPERATIONS_ALERT_FAILED_PAYOUT_THRESHOLD=10
OPERATIONS_ALERT_STALE_TRANSACTION_THRESHOLD=20

MAIL_MAILER=log
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME="${APP_NAME}"

INITIAL_ADMIN_NAME=
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_PASSWORD=

RUN_MIGRATIONS=false
RUN_ADMIN_SEEDER=false
QUEUE_NAMES=webhooks,payouts,default
QUEUE_TRIES=3
QUEUE_TIMEOUT=120
QUEUE_MEMORY=256
QUEUE_SLEEP=3
SCHEDULER_SLEEP=60
